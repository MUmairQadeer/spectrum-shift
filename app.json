{
  "expo": {
    "name": "Spectrum Shift",
    "slug": "spectrum-shift",
    "version": "1.0.0",
    "scheme": "spectrumshift",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.umairdev.spectrumshift"
    },
    "android": {
      "package": "com.umairdev.spectrumshift"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "fb7cc930-958d-4454-a0d2-9a65210a73d3"
      }
    }
  }
}
